{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Yomu",
  "version": "0.1.0",
  "identifier": "com.yomu.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Yomu",
        "width": 1280,
        "height": 800,
        "minWidth": 400,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost http://asset.localhost comic: https://comic.localhost http://comic.localhost; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
